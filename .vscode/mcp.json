{
  "servers": {
    "filesystem": {
      "type": "stdio",
      "command": "pnpm",
      "args": ["-s", "dlx", "@modelcontextprotocol/server-filesystem@2026.1.14", "${workspaceFolder}"]
    },
    "git": {
      "type": "stdio",
      "command": "pnpm",
      "args": ["-s", "dlx", "@cyanheads/git-mcp-server@2.8.4"],
      "env": {
        "MCP_LOG_LEVEL": "error"
      }
    },
    "fetch": {
      "type": "stdio",
      "command": "pnpm",
      "args": ["-s", "dlx", "@lmcc-dev/mult-fetch-mcp-server@1.3.2"],
      "env": {
        "MCP_LANG": "en"
      }
    },
    "playwright": {
      "type": "stdio",
      "command": "pnpm",
      "args": ["-s", "dlx", "@playwright/mcp@0.0.68"]
    },
    "openai_docs": {
      "type": "http",
      "url": "https://developers.openai.com/mcp"
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    }
  }
}
