{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://isa.gs1nl.org/schemas/isa-drift-report.schema.json",
  "title": "ISA Capability Drift Report",
  "type": "object",
  "required": [
    "generated_at",
    "run_id",
    "baseline_path",
    "history_path",
    "summary",
    "status",
    "metrics"
  ],
  "properties": {
    "generated_at": { "type": "string", "format": "date-time" },
    "run_id": { "type": "string" },
    "baseline_path": { "type": "string" },
    "history_path": { "type": "string" },
    "rules": {
      "type": "object",
      "properties": {
        "major_score_degrade_pct": { "type": "number" },
        "major_latency_increase_pct": { "type": "number" },
        "minor_score_degrade_pct": { "type": "number" },
        "minor_latency_increase_pct": { "type": "number" }
      }
    },
    "summary": {
      "type": "object",
      "required": ["major", "minor", "none"],
      "properties": {
        "major": { "type": "integer", "minimum": 0 },
        "minor": { "type": "integer", "minimum": 0 },
        "none": { "type": "integer", "minimum": 0 }
      }
    },
    "status": { "type": "string", "enum": ["pass", "warn", "fail"] },
    "alerts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "metric_id",
          "capability",
          "current",
          "baseline",
          "delta_pct",
          "drift"
        ],
        "properties": {
          "metric_id": { "type": "string" },
          "capability": { "type": "string" },
          "current": { "type": "number" },
          "baseline": { "type": "number" },
          "delta_pct": { "type": "number" },
          "drift": { "type": "string", "enum": ["none", "minor", "major"] },
          "kind": { "type": "string" },
          "direction": { "type": "string", "enum": ["score", "latency"] }
        }
      }
    }
  }
}
