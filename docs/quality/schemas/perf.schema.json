{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://isa.gs1nl.org/schemas/perf.schema.json",
  "title": "ISA Performance Metrics",
  "type": "object",
  "required": ["meta", "status", "thresholds"],
  "anyOf": [
    {"required": ["metrics"]},
    {"required": ["checks"]}
  ],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["generated_at"],
      "properties": {
        "generated_at": {"type": "string", "format": "date-time"}
      }
    },
    "status": {
      "type": "string",
      "enum": ["pass", "fail", "unknown"]
    },
    "metrics": {
      "type": "object",
      "properties": {
        "catalog_p95_latency_ms": {"type": "number", "minimum": 0},
        "catalog_p99_latency_ms": {"type": "number", "minimum": 0},
        "db_query_p95_ms": {"type": "number", "minimum": 0}
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "pass": {"type": "boolean"}
        }
      }
    },
    "thresholds": {
      "type": "object",
      "required": ["catalog_p95_latency_ms_max", "db_query_p95_ms_max"],
      "properties": {
        "catalog_p95_latency_ms_max": {"type": "number", "minimum": 0},
        "catalog_p99_latency_ms_max": {"type": "number", "minimum": 0},
        "db_query_p95_ms_max": {"type": "number", "minimum": 0}
      }
    },
    "unknowns": {
      "type": "array",
      "items": {"type": "string"}
    },
    "capability_eval": {
      "type": "object",
      "required": ["run_id", "latency_p95_ms", "status"],
      "properties": {
        "run_id": {"type": "string"},
        "status": {"type": "string", "enum": ["pass", "fail"]},
        "latency_p95_ms": {
          "type": "object",
          "additionalProperties": {"type": "number", "minimum": 0}
        },
        "generated_at": {"type": "string", "format": "date-time"}
      }
    }
  }
}
