{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://isa.gs1nl.org/schemas/oss-benchmarks-2026-02-15.schema.json",
  "title": "ISA OSS Benchmarks Package (2026-02-15)",
  "description": "Schema for docs/research/oss-benchmarks/2026-02-15/benchmarks.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "repo", "branch", "candidates", "patterns", "action_plan"],
  "properties": {
    "version": { "type": "string", "const": "2026-02-15" },
    "repo": { "type": "string", "minLength": 1 },
    "branch": { "type": "string", "minLength": 1 },
    "candidates": {
      "type": "array",
      "items": { "$ref": "#/definitions/candidate" }
    },
    "patterns": {
      "type": "array",
      "items": { "$ref": "#/definitions/pattern" }
    },
    "action_plan": {
      "type": "array",
      "items": { "$ref": "#/definitions/action_plan_item" }
    }
  },
  "definitions": {
    "date_yyyy_mm_dd_or_empty": {
      "type": "string",
      "pattern": "^UNVERIFIED$|^$|^\\d{4}-\\d{2}-\\d{2}$"
    },
    "evidence_link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "date"],
      "properties": {
        "url": { "type": "string", "minLength": 1 },
        "date": { "$ref": "#/definitions/date_yyyy_mm_dd_or_empty" }
      }
    },
    "signals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stars", "forks", "last_commit_date", "release_date"],
      "properties": {
        "stars": { "type": ["integer", "null"], "minimum": 0 },
        "forks": { "type": ["integer", "null"], "minimum": 0 },
        "last_commit_date": { "$ref": "#/definitions/date_yyyy_mm_dd_or_empty" },
        "release_date": { "$ref": "#/definitions/date_yyyy_mm_dd_or_empty" }
      }
    },
    "why_liked_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim", "evidence_url", "evidence_date"],
      "properties": {
        "claim": { "type": "string", "minLength": 1 },
        "evidence_url": { "type": "string", "minLength": 1 },
        "evidence_date": { "$ref": "#/definitions/date_yyyy_mm_dd_or_empty" }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "url",
        "signals",
        "why_liked",
        "inspect_paths",
        "patterns",
        "avoid",
        "last_verified_date"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 },
        "signals": { "$ref": "#/definitions/signals" },
        "why_liked": {
          "type": "array",
          "items": { "$ref": "#/definitions/why_liked_item" }
        },
        "inspect_paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "patterns": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "avoid": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "last_verified_date": { "type": "string", "const": "2026-02-15" }
      }
    },
    "isa_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_paths", "change_outline", "no_console_strategy"],
      "properties": {
        "target_paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "change_outline": { "type": "string" },
        "no_console_strategy": { "type": "string" }
      }
    },
    "example_repo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "paths"],
      "properties": {
        "url": { "type": "string", "minLength": 1 },
        "paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "pattern": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "summary",
        "evidence",
        "example_repos",
        "tradeoffs",
        "isa_mapping",
        "last_verified_date"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/evidence_link" }
        },
        "example_repos": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/example_repo" }
        },
        "tradeoffs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "isa_mapping": { "$ref": "#/definitions/isa_mapping" },
        "last_verified_date": { "type": "string", "const": "2026-02-15" }
      }
    },
    "action_plan_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "priority",
        "value",
        "effort",
        "risk",
        "files",
        "acceptance_criteria",
        "no_console_compliance",
        "evidence",
        "last_verified_date"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "priority": { "type": "string", "enum": ["P0", "P1", "P2"] },
        "value": { "type": "string" },
        "effort": { "type": "string", "enum": ["S", "M", "L"] },
        "risk": { "type": "string" },
        "files": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "acceptance_criteria": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "no_console_compliance": { "type": "string" },
        "evidence": { "type": "array", "items": { "$ref": "#/definitions/evidence_link" } },
        "last_verified_date": { "type": "string", "const": "2026-02-15" }
      }
    }
  }
}
