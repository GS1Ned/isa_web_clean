{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://isa.gs1nl.org/schemas/oss-benchmarks-2026-02-15.schema.json",
  "title": "ISA OSS Benchmarks Package (2026-02-15)",
  "description": "Schema for docs/research/oss-benchmarks/2026-02-15/benchmarks.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "repo", "branch", "candidates", "patterns", "action_plan"],
  "properties": {
    "version": { "type": "string", "const": "2026-02-15" },
    "repo": { "type": "string", "minLength": 1 },
    "branch": { "type": "string", "minLength": 1 },
    "candidates": {
      "type": "array",
      "items": { "$ref": "#/definitions/candidate" }
    },
    "patterns": {
      "type": "array",
      "items": { "$ref": "#/definitions/pattern" }
    },
    "action_plan": {
      "type": "array",
      "items": { "$ref": "#/definitions/action_plan_item" }
    },
    "capability_rubric": {
      "$ref": "#/definitions/capability_rubric"
    },
    "capability_findings": {
      "type": "array",
      "items": { "$ref": "#/definitions/capability_finding" }
    }
  },
  "definitions": {
    "date_yyyy_mm_dd_or_empty": {
      "type": "string",
      "pattern": "^UNVERIFIED$|^UNKNOWN([_\\-][A-Z0-9]+)*$|^$|^\\d{4}-\\d{2}-\\d{2}$"
    },
    "evidence_link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "date"],
      "properties": {
        "url": { "type": "string", "minLength": 1 },
        "date": { "$ref": "#/definitions/date_yyyy_mm_dd_or_empty" }
      }
    },
    "signals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stars", "forks", "last_commit_date", "release_date"],
      "properties": {
        "stars": { "type": ["integer", "null"], "minimum": 0 },
        "forks": { "type": ["integer", "null"], "minimum": 0 },
        "last_commit_date": { "$ref": "#/definitions/date_yyyy_mm_dd_or_empty" },
        "release_date": { "$ref": "#/definitions/date_yyyy_mm_dd_or_empty" }
      }
    },
    "why_liked_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim", "evidence_url", "evidence_date"],
      "properties": {
        "claim": { "type": "string", "minLength": 1 },
        "evidence_url": { "type": "string", "minLength": 1 },
        "evidence_date": { "$ref": "#/definitions/date_yyyy_mm_dd_or_empty" }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "url",
        "signals",
        "why_liked",
        "inspect_paths",
        "patterns",
        "avoid",
        "last_verified_date"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 },
        "signals": { "$ref": "#/definitions/signals" },
        "why_liked": {
          "type": "array",
          "items": { "$ref": "#/definitions/why_liked_item" }
        },
        "inspect_paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "patterns": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "avoid": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "last_verified_date": { "type": "string", "const": "2026-02-15" }
      }
    },
    "isa_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_paths", "change_outline", "no_console_strategy"],
      "properties": {
        "target_paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "change_outline": { "type": "string" },
        "no_console_strategy": { "type": "string" }
      }
    },
    "example_repo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "paths"],
      "properties": {
        "url": { "type": "string", "minLength": 1 },
        "paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "pattern": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "summary",
        "evidence",
        "example_repos",
        "tradeoffs",
        "isa_mapping",
        "last_verified_date"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/evidence_link" }
        },
        "example_repos": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/example_repo" }
        },
        "tradeoffs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "isa_mapping": { "$ref": "#/definitions/isa_mapping" },
        "last_verified_date": { "type": "string", "const": "2026-02-15" }
      }
    },
    "action_plan_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "priority",
        "value",
        "effort",
        "risk",
        "files",
        "acceptance_criteria",
        "no_console_compliance",
        "evidence",
        "last_verified_date"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "priority": { "type": "string", "enum": ["P0", "P1", "P2"] },
        "value": { "type": "string" },
        "effort": { "type": "string", "enum": ["S", "M", "L"] },
        "risk": { "type": "string" },
        "files": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "acceptance_criteria": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "no_console_compliance": { "type": "string" },
        "evidence": { "type": "array", "items": { "$ref": "#/definitions/evidence_link" } },
        "last_verified_date": { "type": "string", "const": "2026-02-15" }
      }
    },
    "capability_rubric_dimension": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "capability_focus_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capability", "priority_dimensions"],
      "properties": {
        "capability": {
          "type": "string",
          "enum": ["ASK_ISA", "NEWS_HUB", "KNOWLEDGE_BASE", "CATALOG", "ESRS_MAPPING", "ADVISORY"]
        },
        "priority_dimensions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "capability_rubric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dimensions", "scoring_scale", "capability_focus", "evidence_requirements"],
      "properties": {
        "dimensions": {
          "type": "array",
          "items": { "$ref": "#/definitions/capability_rubric_dimension" }
        },
        "scoring_scale": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "capability_focus": {
          "type": "array",
          "items": { "$ref": "#/definitions/capability_focus_item" }
        },
        "evidence_requirements": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source_url_required",
            "retrieval_utc_required",
            "capability_mapping_required",
            "verification_method_required"
          ],
          "properties": {
            "source_url_required": { "type": "boolean" },
            "retrieval_utc_required": { "type": "boolean" },
            "capability_mapping_required": { "type": "boolean" },
            "verification_method_required": { "type": "boolean" }
          }
        }
      }
    },
    "capability_finding_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "retrieved_utc"],
      "properties": {
        "url": { "type": "string", "minLength": 1 },
        "retrieved_utc": { "type": "string", "format": "date-time" }
      }
    },
    "capability_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "capability",
        "references",
        "copyable_practices",
        "minimum_implementation_set",
        "verification_method",
        "manifest_link",
        "backlog_id"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "capability": {
          "type": "string",
          "enum": ["ASK_ISA", "NEWS_HUB", "KNOWLEDGE_BASE", "CATALOG", "ESRS_MAPPING", "ADVISORY"]
        },
        "references": {
          "type": "array",
          "items": { "$ref": "#/definitions/capability_finding_reference" }
        },
        "copyable_practices": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "minimum_implementation_set": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "verification_method": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "manifest_link": { "type": "string", "minLength": 1 },
        "backlog_id": { "type": "string", "minLength": 1 }
      }
    }
  }
}
