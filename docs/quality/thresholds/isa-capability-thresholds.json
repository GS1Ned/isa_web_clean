    "advisory.latency.p95_ms": { "op": "<=", "value": 5000, "enforcement": "fail" },

    "ask.citation.presence": { "op": ">=", "value": 0.9, "enforcement": "warn" },
    "ask.citation.validity": { "op": ">=", "value": 0.8, "enforcement": "warn" },
    "ask.source.diversity": { "op": ">=", "value": 0.5, "enforcement": "warn" },
    "ask.abstention.correctness": { "op": ">=", "value": 0.9, "enforcement": "warn" },
    "ask.answer.completeness": { "op": ">=", "value": 0.8, "enforcement": "warn" },
