    "kb.latency.p95_ms": { "op": "<=", "value": 5000, "enforcement": "warn" },

    "catalog.metadata.completeness": { "op": ">=", "value": 0.9, "enforcement": "warn" },
    "catalog.authority.tier_correctness": { "op": ">=", "value": 0.85, "enforcement": "warn" },
    "catalog.verification.currency_days": { "op": "<=", "value": 730, "enforcement": "warn" },
