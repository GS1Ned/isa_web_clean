# ISA Supabase/Postgres parity template (DB-only migration line)
#
# Use this for ISA2-0011 / ISA2-0013a local parity checks.
# Keep production/runtime secrets out of this file.

DB_ENGINE=postgres
# ISA_DB_ENGINE=postgres  # legacy alias accepted; DB_ENGINE takes precedence

# Active runtime DSN (CURRENT path).
DATABASE_URL=

# Postgres parity DSN (TARGET migration path).
DATABASE_URL_POSTGRES=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Supabase Local endpoints (output from `supabase status -o env`).
SUPABASE_LOCAL_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_LOCAL_STUDIO_URL=http://127.0.0.1:54323

# Optional direct PG vars used by tooling.
PGHOST=127.0.0.1
PGPORT=54322
PGDATABASE=postgres
PGUSER=postgres
PGPASSWORD=postgres
