{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gs1isa.com/schemas/dataset-registry.schema.json",
  "title": "ISA Dataset Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "registryVersion",
    "generatedAt"
  ],
  "properties": {
    "registryVersion": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "generatedBy": {
      "type": "string"
    },
    "asrMetadataDefaults": {
      "$ref": "#/$defs/asrMetadataDefaults"
    },
    "notes": {
      "type": "string"
    },
    "summary": {
      "type": "object"
    },
    "changelog": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/changelogEntry"
      }
    },
    "datasets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/datasetLike"
      }
    },
    "newDatasets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/datasetLike"
      }
    },
    "registeredStandards": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/standardLike"
      }
    }
  },
  "allOf": [
    {
      "anyOf": [
        {
          "required": [
            "datasets"
          ]
        },
        {
          "required": [
            "newDatasets",
            "registeredStandards"
          ]
        }
      ]
    }
  ],
  "$defs": {
    "asrMetadataDefaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "authorityTierByDomain": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "publicationStatusDefault": {
          "type": "string",
          "minLength": 1
        },
        "immutableUriPolicy": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "changelogEntry": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "date": {
          "type": "string"
        },
        "changes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "datasetLike": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "title",
        "publisher",
        "version"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "publisher": {
          "type": "string",
          "minLength": 1
        },
        "jurisdiction": {
          "type": "string"
        },
        "sourceType": {
          "type": "string"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "releaseDate": {
          "type": "string"
        },
        "effectiveDate": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "canonicalDomains": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "language": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "license": {
          "type": "object"
        },
        "access": {
          "type": "object"
        },
        "formats": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "repoAssets": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "lineage": {
          "type": "object"
        },
        "ingestion": {
          "type": "object"
        }
      }
    },
    "standardLike": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "title",
        "publisher",
        "version"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "publisher": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string"
        },
        "standard": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "pubDate": {
          "type": "string"
        },
        "effectiveDate": {
          "type": "string"
        },
        "canonicalSourcePage": {
          "type": "string"
        },
        "directDownloadLink": {
          "type": "string"
        },
        "fileFormat": {
          "type": "string"
        }
      }
    }
  }
}
