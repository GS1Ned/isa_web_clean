{
  "mcpServers": {
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem@2026.1.14", "."]
    },
    "git": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@cyanheads/git-mcp-server@2.8.4"],
      "env": {
        "MCP_LOG_LEVEL": "error",
        "GIT_BASE_DIR": "."
      }
    },
    "fetch": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@lmcc-dev/mult-fetch-mcp-server@1.3.2"],
      "env": {
        "MCP_LANG": "en"
      }
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@0.0.68"]
    },
    "openai_docs": {
      "type": "http",
      "url": "https://developers.openai.com/mcp"
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    }
  }
}
