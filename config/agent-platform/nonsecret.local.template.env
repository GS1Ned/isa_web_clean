# ISA agent-fabric non-secret local variables
# Copy or render to: ~/.config/isa-agent-fabric/nonsecret.env
# This file must never contain secrets.

# Google Cloud project to use with Gemini Code Assist Standard or Gemini CLI
GOOGLE_CLOUD_PROJECT=

# Default launch lane for the local VS Code launcher
ISA_AGENT_FABRIC_DEFAULT_LAUNCH_LANE=scm_only

# Optional preferred VS Code window title/profile label for human orientation
ISA_AGENT_FABRIC_LABEL='ISA Agent Fabric'
