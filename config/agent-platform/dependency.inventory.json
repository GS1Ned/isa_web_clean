    "version_strategy": "packageManager_field_compatible",
    "license_or_tier": "free",
    "owner": "developer_workstation_and_vm",
    "provisioning_mode": "bootstrap_check_only",
    "validation_command": "pnpm --version",
    "notes": "Repo pins `pnpm@10.30.1` in `package.json`."
  },
  {
    "component_id": "github_cli",
    "component_type": "cli",
    "install_target": "host",
    "required_for": ["github_issue_ops", "pr_flows", "token_validation"],
    "source": "https://cli.github.com/",
    "version_strategy": "latest_stable",
    "license_or_tier": "free_with_account",
    "owner": "developer_workstation",
    "provisioning_mode": "bootstrap_install_or_existing",
    "validation_command": "gh --version",
    "notes": "Preferred for validating GitHub auth locally without exposing token material."
