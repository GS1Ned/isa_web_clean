    "version_strategy": "stable_current",
    "license_or_tier": "free",
    "owner": "developer_workstation",
    "provisioning_mode": "manual_or_bootstrap",
    "validation_command": "code --version",
    "notes": "Primary interactive editing surface for ISA."
  },
  {
