    "license_or_tier": "standard_compatible",
    "owner": "developer_workstation",
    "provisioning_mode": "bootstrap_install",
    "validation_command": "gemini --version",
    "notes": "Not installed in the current workstation state."
  },
  {
    "component_id": "codex_cli_or_extension",
