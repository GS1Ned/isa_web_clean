  {
    "component_id": "mcp_server_runtime_packages",
    "component_type": "toolchain_bundle",
    "install_target": "host",
    "required_for": ["filesystem_mcp", "git_mcp", "fetch_mcp", "playwright_mcp", "sequential_thinking_mcp"],
