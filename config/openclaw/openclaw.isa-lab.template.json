  },
  "agents": {
    "defaults": {
      "heartbeat": {
        "every": "30m",
        "suppressToolErrorWarnings": true
      },
      "workspace": "docs/agent/_runtime"
    }
  },
  "tools": {
    "profile": "full"
  },
  "TBD_UNVERIFIED": {
    "agents": {
      "defaults": {
        "repoRoot": {
          "intended_source": "repo root detected by scripts/openclaw-isa-autonomy-setup.sh"
        }
      }
    },
