{
  "_meta": {
    "evidence": {
      "documented_keys": [
        "agents.defaults.heartbeat",
        "agents.defaults.workspace",
        "tools.profile"
      ],
      "note": "Cron and memory tuning are applied via CLI/runtime setup because matching config keys were not proven from local docs during this run."
