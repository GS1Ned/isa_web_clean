# ISA Environment Configuration (Template)
#
# Copy this file to `.env` and fill values. Never commit `.env`.
# For focused Postgres parity bootstrap, use `.env.supabase.example`.

# Core (required)
VITE_APP_ID=
JWT_SECRET=
DATABASE_URL=
DB_ENGINE=mysql
# ISA_DB_ENGINE=mysql  # legacy alias accepted; DB_ENGINE takes precedence

# Postgres/Supabase migration line (DB-only scope)
# Keep DATABASE_URL as the legacy runtime DSN until cutover.
# Use DB_ENGINE=postgres + DATABASE_URL_POSTGRES for the verified remote Supabase target.
DATABASE_URL_POSTGRES=
# Optional MCP-specific Postgres DSN when Node-based tooling needs a different SSL mode.
POSTGRES_MCP_URL=
# Deprecated for this workspace: do not point Postgres tooling at localhost.
SUPABASE_LOCAL_DB_URL=
SUPABASE_LOCAL_STUDIO_URL=

# Manus / Auth (as used by this repo)
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
MANUS_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# LLM
# Manus embeddings proxy base (optional; used for embeddings created via Manus)
OPENAI_BASE_URL=
# ISA runtime key (do not break)
OPENAI_API_KEY=
# Direct OpenAI (must exist for direct OpenAI calls)
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY_OPENAI=

BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_KEY=

# GitHub tokens (user tokens; keep in local .env only)
GITHUB_PAT=
GH_TOKEN=
GITHUB_TOKEN=

# Optional GitHub App
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_ID=
INSTALLATION_ID=

# Deprecated (historical): TiDB keypair
# Keep empty; do not use in new environments.
TIDB_PRIVATE_KEY=
TIDB_PUBLIC_KEY=

# Cron
CRON_SECRET=

# Email (optional)
SENDGRID_API_KEY=
SENDER_EMAIL=
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASSWORD=

# Runtime toggles (optional)
NODE_ENV=
PORT=
VITE_APP_URL=
ISA_ADVISORY_VERSION=
ISA_OTEL_ENABLED=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=
ISA_SERVICE_VERSION=
RUN_DB_TESTS=
RUN_CELLAR_TESTS=
RUN_LLM_TESTS=
VITEST=
ISA_TEST_SILENT=
DOTENV_CONFIG_QUIET=

# Alternate DB vars (optional)
DB_HOST=
DB_NAME=
DB_PASSWORD=
DB_USER=
PGHOST=
PGPORT=
PGDATABASE=
PGUSER=
PGPASSWORD=

# Frontend analytics (optional)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Portal URL (optional)
VITE_OAUTH_PORTAL_URL=

# VM access (optional; used for ISA + OpenClaw VM automation)
ISA_VM_HOST=
ISA_VM_IP=
ISA_VM_USER=
ISA_VM_SSH_KEY=
VM_SSH_HOST=
VM_SSH_PORT=22
VM_REPO_PATH=
VM_ENV_PATH=

# OpenClaw integration (optional for Host <-> VM workflows)
# `OPENCLAW_GATEWAY_TOKEN` is VM-authoritative and should stay secret on VM.
# `OPENCLAW_CONFIG_PATH` is the VM runtime materialization target, not the SSOT.
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_STATE_DIR=/root/.openclaw
OPENCLAW_CONFIG_PATH=/root/.openclaw/openclaw.json
OPENCLAW_DASHBOARD_URL_FILE=/root/.openclaw/dashboard-url.latest
OPENCLAW_RUNTIME_MODE=vm_only
OPENCLAW_POLICY_ENVELOPE_PATH=config/governance/openclaw_policy_envelope.json
OPENCLAW_AUTOMATION_STRICT_MODE=
OPENCLAW_AUTOMATION_ALLOW_INSECURE_DEV_BYPASS=1
OPENCLAW_AUTOMATION_KILL_SWITCH=0
OPENCLAW_AUTOMATION_MAX_SKEW_SECONDS=300
OPENCLAW_EXEC_POLICY_PATH=config/openclaw/exec-lane.policy.json
OPENCLAW_SKILLS_ALLOWLIST_PATH=config/openclaw/skills-allowlist.json
OPENCLAW_BROWSER_POLICY_PATH=config/openclaw/browser.policy.json
OPENCLAW_BROWSER_POLICY_MODE=
OPENCLAW_BROWSER_FALLBACK_ALLOWED=0
OPENCLAW_BROWSER_ALLOW_UNSAFE_FLAGS=0
OPENCLAW_REVERSE_PROXY_EXPOSURE=0
OPENCLAW_TRUSTED_PROXIES=

# Verified external service credentials (local values only)
SUPABASE_API_KEY=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_HOST=
POSTGRES_PORT=
NEO4J_CLIENT_ID=
NEO4J_CLIENT_SECRET=
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=
NEO4J_READ_ONLY=false
